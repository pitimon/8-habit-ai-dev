{
  "description": "8-Habit AI Dev hooks — session reminder for 7-step workflow",
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "PLUGIN_ROOT=\"${CLAUDE_PLUGIN_ROOT:-${CODEX_MANAGED_PACKAGE_ROOT:-.}}\"; CLAUDE_PLUGIN_ROOT=\"$PLUGIN_ROOT\" bash \"$PLUGIN_ROOT/hooks/session-start.sh\""
          }
        ]
      }
    ]
  }
}
